# Local Pi state and captured sessions
/.pi/
/archive/
/system-instruction/baseline/

# Independent local reference checkouts; not part of this repository.
/references/

# Generated build and dependency state
/build/
**/node_modules/
*.tgz
*.tsbuildinfo
**/coverage/
/mcp-extension/dist/

# Machine-local Claude Code settings (keep shared skills and project instructions trackable)
**/.claude/settings.local.json

# Local environment and credentials
.env
.env.*
!.env.example
*.pem
*.key

# Tool logs and local editor noise
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log
.DS_Store
*.swp
*.swo
*~

# pi-mono/ is intentionally not ignored: it is managed as an upstream submodule.
