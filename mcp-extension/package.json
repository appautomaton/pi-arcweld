{
  "name": "pi-mcp-client-local",
  "version": "0.1.0",
  "private": true,
  "description": "A small, security-first MCP client extension for Pi",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "pi-extension",
    "mcp",
    "model-context-protocol"
  ],
  "files": [
    "src/",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "scripts": {
    "check": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "pack:check": "npm pack --dry-run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "@cfworker/json-schema": "4.1.1",
    "zod": "4.4.3"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": "0.80.6",
    "@earendil-works/pi-coding-agent": "0.80.6",
    "@earendil-works/pi-tui": "0.80.6",
    "typebox": "1.1.38"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "0.80.6",
    "@earendil-works/pi-coding-agent": "0.80.6",
    "@earendil-works/pi-tui": "0.80.6",
    "@types/node": "24.13.3",
    "tsx": "4.23.0",
    "typebox": "1.1.38",
    "typescript": "5.9.3"
  }
}
